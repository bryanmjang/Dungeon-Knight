  portrait: {fileID: 6660783624410144326, guid: 72d6721947b184740bc0188ae413538a, type: 3}
  talkingClip: {fileID: 8300000, guid: 84a640c09c50b40898a0744dfb4175c7, type: 3}
  sentences:
  - 'Old bones laid piled atop each other in a crude display of warning. An old sign
    written in some holy language reads:'
  - A greate dragone hath torn our landes to soundre. Onliye a hero equaliye az graete
    shall save us....
